# ──────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente para o serviço Railway — WeCare Calculadora de Preços
# Copie este arquivo, preencha os valores e configure no Railway Dashboard:
#   Settings → Variables → Add Variable
# ──────────────────────────────────────────────────────────────────────────

# ── Clerk Auth ──────────────────────────────────────────────────────────────
# Encontre no Clerk Dashboard → API Keys
CLERK_SECRET_KEY=sk_live_...

# Chave pública (pk_live_...) — servida em runtime via /clerk-frontend-config.js
CLERK_PUBLISHABLE_KEY=pk_live_...

# URL pública do serviço Railway (ex: https://calculadora-preco-production.up.railway.app)
# Usada para validar o claim "azp" do JWT Clerk
# Separe múltiplas origens por vírgula
CLERK_AUTHORIZED_PARTIES=https://SEU-SERVICO.up.railway.app

# URL do JWKS do Clerk — deixe em branco para usar o padrão (via CLERK_SECRET_KEY)
# CLERK_JWKS_URL=https://SEU-DOMINIO.clerk.accounts.dev/.well-known/jwks.json

# ── Hostaway ────────────────────────────────────────────────────────────────
HOSTAWAY_ACCOUNT_ID=53296
HOSTAWAY_API_KEY=sua_chave_hostaway_aqui

# ── PriceLabs ───────────────────────────────────────────────────────────────
PRICELABS_API_KEY=sua_chave_pricelabs_aqui

# ── CORS ────────────────────────────────────────────────────────────────────
# Em produção Railway o frontend é servido pelo mesmo backend (mesma origem),
# então CORS só é necessário se houver clientes externos.
# Use a URL pública do serviço ou "*" para liberar tudo.
CORS_ORIGINS=https://SEU-SERVICO.up.railway.app
